PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/grandtour_crm?schema=public"

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_please_change_in_production
JWT_EXPIRES_IN=7d

# Placeholder for future integrations
EMAIL_SERVICE_API_KEY=your_email_api_key

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Configuration
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password


# Google Meet / Google Calendar integration for automatic interview links
# Create a service account in Google Cloud Console, download the JSON key, and copy:
# - client_email -> GOOGLE_MEET_SERVICE_ACCOUNT_EMAIL
# - private_key -> GOOGLE_MEET_PRIVATE_KEY (keep the \n escapes or paste multiline value)
# - calendar email or calendar ID to create events in -> GOOGLE_MEET_CALENDAR_ID
GOOGLE_MEET_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_MEET_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_MEET_CALENDAR_ID=your-calendar-email@example.com